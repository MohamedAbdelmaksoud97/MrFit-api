# 1. Dependency directories
node_modules/
jspm_packages/

# 2. Environment Variables (IMPORTANT: Never upload these)
.env
.env.*
!.env.example

# 3. TypeScript & Compilation
# We ignore the backend build (dist-server) but NOT the frontend build (dist)
# If your backend build folder is named something else, add it here
dist-server/
*.tsbuildinfo

# 4. Logs & Debugging
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. OS Metadata & IDEs
.DS_Store
Thumbs.db
.vscode/
.idea/
.project
.settings/

# 6. Temporary & Cache
.npm
.cache
.parcel-cache
.eslintcache
.node_repl_history

# 7. Frontend specific (Vite/React/Next)
# We keep the 'dist' folder because your server needs it to serve the UI
# But we ignore other temporary outputs
.next
out
.nuxt
.temp
**/.vitepress/cache
.svelte-kit/